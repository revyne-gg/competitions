<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <!-- GitLab Package Registry for the proto project.
         One-time login (stores credentials in ~/.nuget/NuGet/NuGet.Config):
           dotnet nuget add source URL -n gitlab -u YOUR_USERNAME -p YOUR_PAT
               also pass: store-password-in-clear-text
         In CI: credentials injected via GITLAB_TOKEN / CI_JOB_TOKEN -->
    <add key="gitlab" value="https://gitlab.com/api/v4/groups/115866769/-/packages/nuget/index.json" />
  </packageSources>
</configuration>
