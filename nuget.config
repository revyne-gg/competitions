<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <!-- GitLab Package Registry for the proto project.
         One-time login (stores credentials in ~/.nuget/NuGet/NuGet.Config):
           dotnet nuget add source URL -n gitlab -u YOUR_USERNAME -p YOUR_PAT
               -n  = name gitlab
               -u  = your GitLab username
               -p  = Personal Access Token with read_api scope
               also pass: store-password-in-clear-text
         In CI: credentials injected via GITLAB_TOKEN build arg (see Dockerfile + .gitlab-ci.yml) -->
    <add key="gitlab"
         value="https://gitlab.com/api/v4/projects/esports-league%2Fbackend%2Fproto/packages/nuget/index.json" />
    <!-- Local source for iterating on proto without publishing.
         Run `dotnet pack -c Release` in platform/proto first. -->
    <add key="local-proto"
         value="../proto/bin/Release/" />
  </packageSources>
</configuration>
